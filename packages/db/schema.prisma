generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActionLog {
  id           String    @id @default(cuid())
  userId       String
  campaignId   String?
  leadId       String?
  actionType   String
  status       String    @default("SUCCESS")
  errorMessage String?
  executedAt   DateTime  @default(now())
  Campaign     Campaign? @relation(fields: [campaignId], references: [id])
  Lead         Lead?     @relation(fields: [leadId], references: [id])
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  name                  String?
  company               String?
  persona               String?
  valueProp             String?
  style                 String?
  keywords              String[]  @default([])
  targetAudience        String?
  industry              String?
  website               String?
  heardFrom             String?
  mainPainPoint         String?
  usp                   String?
  companyDescription    String?
  products              String?
  differentiators       String?
  caseStudies           String?
  communicationStyle    String?
  writingSamples        Json?
  tonePreferences       String[]  @default([])
  aiStrategy            Json?
  aiStrategyGeneratedAt DateTime?
  websiteScrapedAt      DateTime?
  // Self-profile enrichment: scraped from the user's OWN LinkedIn profile after
  // they complete login through Qampi. Populated once by the enrichment job.
  selfHeadline          String?
  selfAbout             String?
  selfRecentPosts       Json?     // [{ url, content, date }]
  selfProfileSummary    String?
  selfProfileEnrichedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  User                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StrategyHistory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version        Int
  generatedAt    DateTime @default(now())
  trigger        String
  inputSnapshot  Json
  outputStrategy Json
  reviewIssues   Json?
  performance    Json?

  @@index([userId, version])
}

model Campaign {
  id                   String                 @id @default(cuid())
  userId               String
  name                 String
  status               CampaignStatus         @default(DRAFT)
  // Position in the user's FIFO queue when status=QUEUED. Null when not queued.
  // Lower = earlier promotion. Only one ACTIVE per user; QUEUED campaigns
  // promote one-at-a-time as the active campaign terminates.
  queuePosition        Int?
  workflow             Json?
  workflowJson         Json?
  objective            String?
  description          String? // Campaign description for AI-generated messages
  cta                  String?
  toneOverride         String?
  createdAt            DateTime               @default(now())
  ActionLog            ActionLog[]
  User                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  CampaignLead         CampaignLead[]
  CampaignLeadProgress CampaignLeadProgress[]
  WorkerLog            WorkerLog[]
  CampaignCrmPolicy    CampaignCrmPolicy?
  CrmSyncEvent         CrmSyncEvent[]

  @@index([userId, status])
  @@index([userId, queuePosition])
  @@index([status])
}

model CampaignLead {
  id              String     @id @default(cuid())
  campaignId      String
  leadId          String
  stepIndex       Int        @default(0)
  currentStepId   String?
  nextActionDate  DateTime?  @default(now())
  lastActionAt    DateTime?
  isCompleted     Boolean    @default(false)
  status          LeadStatus @default(PENDING)
  personalization Json?
  Campaign        Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  Lead            Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId, isCompleted, nextActionDate])
}

model CampaignLeadProgress {
  id                  String        @id @default(cuid())
  campaignId          String
  leadId              String
  connectionStatus    String        @default("not_connected")
  lastConnectionCheck DateTime?
  currentNodeIndex    Int           @default(0)
  needsRetry          Boolean       @default(false)
  nextRetryAt         DateTime?
  completedAt         DateTime?
  status              LeadRunStatus @default(PENDING)
  statusReason        String?
  deferralCount       Int           @default(0)
  terminalAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now())
  Campaign            Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  Lead                Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([status, nextRetryAt])
  @@index([campaignId, status])
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String
  tag       String
  createdAt DateTime @default(now())
  Lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, tag])
}

model Integration {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  webhookUrl String?
  isActive   Boolean  @default(true)
  config     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Lead {
  id                   String                 @id @default(cuid())
  userId               String
  linkedinUrl          String
  firstName            String?
  lastName             String?
  headline             String?
  jobTitle             String?
  company              String?
  location             String?
  email                String?
  phone                String?
  country              String?
  gender               String?
  // 1 = 1st-degree (already connected), 2 = 2nd-degree, 3 = 3rd-degree+.
  // null = unknown (legacy/manual imports, or LinkedIn didn't render the
  // badge). Captured at scrape time by the Chrome extension when visible
  // in search results, and re-written canonically by PROFILE_VISIT and
  // CHECK_CONNECTION when they read it off a profile page. Lets templates
  // branch via IF_ELSE without a runtime DOM probe — fast path for known
  // 1st-degree leads skips the CONNECT+wait+CHECK_CONNECTION dance.
  connectionDegree     Int?
  // Raw text snippet from the LinkedIn search-result card the extension
  // scraped this lead from. Captures everything visible (name, degree,
  // role line, location, "Provides services - ..." secondary lines) so
  // the qampi UI can show "what the user saw on LinkedIn" alongside the
  // parsed fields. Capped to ~1000 chars at scrape time.
  info                 String?
  tags                 String[]               @default([])
  status               LeadStatus             @default(IMPORTED)
  aboutInfo            String?
  latestPost           String?
  latestPostUrl        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  ActionLog            ActionLog[]
  CampaignLead         CampaignLead[]
  CampaignLeadProgress CampaignLeadProgress[]
  LeadTag              LeadTag[]
  User                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  Message              Message[]
  WorkerLog            WorkerLog[]

  @@unique([userId, linkedinUrl])
  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  userId     String
  leadId     String
  campaignId String?
  templateId String?
  direction  String
  // Distinguishes LinkedIn DMs from email sends so the inbox UI can
  // filter by channel and the engine knows which write-path created
  // the row (audit, replay, reply-pause scope).
  channel    String   @default("linkedin")
  // Email-only metadata. Subject is null for LinkedIn messages.
  // messageId is the RFC-2822 Message-Id we emit, so replies can be
  // threaded back when we add IMAP/Gmail-inbox sync.
  subject    String?
  messageId  String?
  content    String
  source     String   @default("MANUAL")
  sentAt     DateTime @default(now())
  Lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, sentAt])
}

// SMTP credentials for sending email from a campaign EMAIL node. One
// row per user. Password is encrypted with CRM_ENCRYPTION_KEY (we
// reuse the existing secret rather than introducing a second one).
//
// `provider` is a free-form tag — 'smtp' today, 'gmail-oauth' /
// 'microsoft-oauth' when those land. OAuth flow will add
// oauthRefreshToken/oauthAccessToken and zero out smtpPass.
model EmailAccount {
  id                String   @id @default(cuid())
  userId            String   @unique
  provider          String   @default("smtp")
  fromEmail         String
  fromName          String?
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPass          String?
  smtpSecure        Boolean  @default(false)
  oauthRefreshToken String?
  oauthAccessToken  String?
  oauthExpiresAt    DateTime?
  lastSendAt        DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   String
  variables String[] @default([])
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("INFO")
  meta      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Proxy {
  id             String    @id @default(cuid())
  proxyIp        String    @unique
  proxyHost      String
  proxyPort      Int
  proxyUsername  String?
  proxyPassword  String?
  proxyCountry   String?
  tierClass      ProxyTier @default(ECONOMY)
  maxUsers       Int       @default(15)
  isAssigned     Boolean   @default(false)
  lockedUntil    DateTime?
  lockedByUserId String?
  failureCount   Int       @default(0)
  banned         Boolean   @default(false)
  linkedinBanned Boolean   @default(false)
  bannedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  User           User[]
}

model SmartList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Team {
  id         String       @id @default(cuid())
  name       String
  ownerId    String
  createdAt  DateTime     @default(now())
  TeamInvite TeamInvite[]
  TeamMember TeamMember[]
}

model TeamInvite {
  id        String       @id @default(cuid())
  teamId    String
  email     String
  role      TeamRole     @default(MEMBER)
  token     String       @unique
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  expiresAt DateTime
  Team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())
  Team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model User {
  id                      String            @id @default(cuid())
  email                   String            @unique
  firstName               String?
  lastName                String?
  passwordHash            String?
  googleId                String?           @unique
  githubId                String?           @unique
  avatarUrl               String?
  registrationStep        String            @default("STARTED")
  tier                    SubscriptionTier  @default(FREE)
  trialEndsAt             DateTime?
  dailyInviteLimit        Int               @default(20)
  proxyIp                 String?
  linkedinPlan            LinkedinPlan      @default(BASIC)
  workingDays             Int[]             @default([1, 2, 3, 4, 5])
  workingHours            Json?
  linkedinCookie          String?
  linkedinLocalStorage    String?
  linkedinFingerprint     String?
  // Exact proxy used at LinkedIn login. Sticky for the lifetime of the
  // saved session — every campaign run, profile visit, message send must
  // egress through this same proxy at Playwright LAUNCH level. If LinkedIn
  // sees cookies from one IP being used from another, the session is
  // invalidated server-side. JSON shape: { server, username, password }.
  linkedinProxySnapshot   Json?
  persistentSessionPath   String?
  actualCountry           String?
  linkedinActiveInBrowser Boolean           @default(false)
  lastBrowserActivityAt   DateTime?
  cloudWorkerActive       Boolean           @default(false)
  lastCloudActionAt       DateTime?
  proxyId                 String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @default(now())
  linkedinUrl             String?
  lastOnboardingEmailAt   DateTime?
  hubspotToken            String? // Encrypted HubSpot Private Access Token
  pipedriveToken          String? // Encrypted Pipedrive API Token
  notionToken             String? // Encrypted Notion Internal Integration Token
  notionDatabaseId        String? // Encrypted Notion Database ID
  profileData             Json?
  sessionInvalid          Boolean           @default(false)
  sessionPath             String?
  sessionValidatedAt      DateTime?
  // Account health: richer than the binary sessionInvalid flag — distinguishes
  // "session expired" (re-login fine) from "OTP_REQUIRED" (need user-side
  // verification code) from "RESTRICTED" (LinkedIn punted the account, manual
  // recovery). The engine refuses to launch unless this is HEALTHY; the
  // recovery flow flips it back via loginWithOtp.
  accountHealth           AccountHealth     @default(HEALTHY)
  accountHealthReason     String?
  accountHealthAt         DateTime?
  ActionLog               ActionLog[]
  BusinessProfile         BusinessProfile?
  StrategyHistory         StrategyHistory[]
  Campaign                Campaign[]
  Integration             Integration[]
  Lead                    Lead[]
  Message                 Message[]
  MessageTemplate         MessageTemplate[]
  Notification            Notification[]
  SmartList               SmartList[]
  TeamMember              TeamMember[]
  Proxy                   Proxy?            @relation(fields: [proxyId], references: [id])
  WorkerLog               WorkerLog[]
  EmailAccount            EmailAccount?

  @@index([updatedAt])
}

model WorkerLog {
  id           String    @id @default(cuid())
  userId       String
  campaignId   String?
  leadId       String?
  action       String
  status       String
  errorMessage String?
  createdAt    DateTime  @default(now())
  Campaign     Campaign? @relation(fields: [campaignId], references: [id])
  Lead         Lead?     @relation(fields: [leadId], references: [id])
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Per-campaign event-driven CRM sync policy. One row per campaign; absence
// of a row means "no auto-sync" (legacy CRM_SYNC node behavior, if any node
// still exists). New campaigns get a row with sensible defaults on first
// start when the user has any CRM connected.
model CampaignCrmPolicy {
  campaignId        String   @id
  enabled           Boolean  @default(true)
  syncOnAdded       Boolean  @default(true)
  syncOnConnected   Boolean  @default(true)
  syncOnMessaged    Boolean  @default(false)
  syncOnReplied     Boolean  @default(true)
  syncOnBounced     Boolean  @default(true)
  syncOnCompleted   Boolean  @default(false)
  createTaskOnReply Boolean  @default(true)
  ownerEmail        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  Campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// Audit log of every CRM sync attempt. Powers the "synced 3m ago" UI on the
// campaign detail CRM tab, and lets us debug per-provider failures without
// trawling stdout. One row per (event, provider) — a single lead.replied
// event with both HubSpot and Pipedrive connected produces two rows.
model CrmSyncEvent {
  id         String    @id @default(cuid())
  userId     String
  campaignId String
  leadId     String
  event      String // lead.added | lead.connected | lead.messaged | lead.replied | lead.bounced | lead.completed
  provider   String // hubspot | pipedrive | notion
  status     String // SUCCESS | FAILED | SKIPPED
  externalId String? // CRM-side ID returned on success
  error      String?
  meta       Json?
  createdAt  DateTime  @default(now())
  Campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([leadId, event])
}

enum CampaignStatus {
  DRAFT
  QUEUED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum LeadRunStatus {
  PENDING
  IN_PROGRESS
  DEFERRED
  REPLIED
  COMPLETED
  STALLED
  FAILED
}

enum AccountHealth {
  HEALTHY
  OTP_REQUIRED
  SESSION_EXPIRED
  RESTRICTED
  NEEDS_LOGIN
}

enum InviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum LeadStatus {
  IMPORTED
  PENDING
  CONNECTED
  REPLIED
  BOUNCED
}

enum LinkedinPlan {
  BASIC
  PREMIUM
  SALES_NAV
}

enum ProxyTier {
  ECONOMY
  RESIDENTIAL
}

enum SubscriptionTier {
  FREE
  CORE
  PRO
  ADVANCED
  PLUS
  EXPERT
  ULTIMATE
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}
