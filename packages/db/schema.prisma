generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActionLog {
  id           String    @id
  userId       String
  campaignId   String?
  leadId       String?
  actionType   String
  status       String    @default("SUCCESS")
  errorMessage String?
  executedAt   DateTime  @default(now())
  Campaign     Campaign? @relation(fields: [campaignId], references: [id])
  Lead         Lead?     @relation(fields: [leadId], references: [id])
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
  id             String   @id
  userId         String   @unique
  name           String?
  company        String?
  persona        String?
  valueProp      String?
  style          String?
  keywords       String[] @default([])
  targetAudience String?
  industry       String?
  website        String?
  heardFrom      String?
  mainPainPoint  String?
  usp            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String         @id @default(cuid())
  userId       String
  name        String
  status      CampaignStatus @default(DRAFT)
  workflow    Json?
  workflowJson Json?
  objective   String?
  description String?    // Campaign description for AI-generated messages
  cta         String?
  toneOverride String?
  createdAt   DateTime     @default(now())
  ActionLog   ActionLog[]
  User       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  CampaignLead CampaignLead[]
  CampaignLeadProgress CampaignLeadProgress[]
  WorkerLog  WorkerLog[]
}

model CampaignLead {
  id              String     @id
  campaignId      String
  leadId          String
  stepIndex       Int        @default(0)
  currentStepId   String?
  nextActionDate  DateTime?  @default(now())
  lastActionAt    DateTime?
  isCompleted     Boolean    @default(false)
  status          LeadStatus @default(PENDING)
  personalization Json?
  Campaign        Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  Lead            Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
}

model CampaignLeadProgress {
  id                  String     @id @default(cuid())
  campaignId          String
  leadId              String
  connectionStatus   String     @default("not_connected")
  lastConnectionCheck DateTime?
  currentNodeIndex    Int        @default(0)
  needsRetry          Boolean    @default(false)
  nextRetryAt         DateTime?
  completedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @default(now())
  Campaign            Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  Lead                Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String
  tag       String
  createdAt DateTime @default(now())
  Lead      Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, tag])
}

model Integration {
  id         String   @id
  userId     String
  provider   String
  webhookUrl String?
  isActive   Boolean  @default(true)
  config     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Lead {
  id            String         @id
  userId        String
  linkedinUrl   String
  firstName     String?
  lastName      String?
  headline      String?
  jobTitle      String?
  company       String?
  location      String?
  email         String?
  country       String?
  gender        String?
  tags          String[]       @default([])
  status        LeadStatus     @default(IMPORTED)
  aboutInfo     String?
  latestPost    String?
  latestPostUrl String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  ActionLog     ActionLog[]
  CampaignLead  CampaignLead[]
  CampaignLeadProgress CampaignLeadProgress[]
  LeadTag        LeadTag[]
  User          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  Message       Message[]
  WorkerLog     WorkerLog[]

  @@unique([userId, linkedinUrl])
}

model Message {
  id         String   @id
  userId     String
  leadId     String
  campaignId String?
  templateId String?
  direction  String
  content    String
  source     String   @default("MANUAL")
  sentAt     DateTime @default(now())
  Lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MessageTemplate {
  id        String   @id
  userId    String
  name      String
  content   String
  variables String[] @default([])
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Notification {
  id        String   @id
  userId    String
  title     String
  body      String
  type      String   @default("INFO")
  meta      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Proxy {
  id             String    @id
  proxyIp        String    @unique
  proxyHost      String
  proxyPort      Int
  proxyUsername  String?
  proxyPassword  String?
  proxyCountry   String?
  tierClass      ProxyTier @default(ECONOMY)
  maxUsers       Int       @default(15)
  isAssigned     Boolean   @default(false)
  lockedUntil    DateTime?
  lockedByUserId String?
  failureCount   Int       @default(0)
  banned         Boolean   @default(false)
  linkedinBanned Boolean   @default(false)
  bannedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  User           User[]
}

model SmartList {
  id        String   @id
  userId    String
  name      String
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Team {
  id         String       @id
  name       String
  ownerId    String
  createdAt  DateTime     @default(now())
  TeamInvite TeamInvite[]
  TeamMember TeamMember[]
}

model TeamInvite {
  id        String       @id
  teamId    String
  email     String
  role      TeamRole     @default(MEMBER)
  token     String       @unique
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  expiresAt DateTime
  Team      Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        String   @id
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())
  Team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model User {
  id                      String            @id @default(cuid())
  email                   String            @unique
  firstName               String?
  lastName                String?
  passwordHash            String?
  googleId                String?           @unique
  githubId                String?           @unique
  avatarUrl               String?
  registrationStep        String            @default("STARTED")
  tier                    SubscriptionTier  @default(FREE)
  trialEndsAt             DateTime?
  dailyInviteLimit        Int               @default(20)
  proxyIp                 String?
  linkedinPlan            LinkedinPlan      @default(BASIC)
  workingDays             Int[]             @default([1, 2, 3, 4, 5])
  workingHours            Json?
  linkedinCookie          String?
  linkedinLocalStorage    String?
  linkedinFingerprint     String?
  persistentSessionPath   String?
  actualCountry           String?
  linkedinActiveInBrowser Boolean           @default(false)
  lastBrowserActivityAt   DateTime?
  cloudWorkerActive       Boolean           @default(false)
  lastCloudActionAt       DateTime?
  proxyId                 String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime
  linkedinUrl             String?
  lastOnboardingEmailAt   DateTime?
  profileData             Json?
  sessionInvalid          Boolean           @default(false)
  sessionPath             String?
  sessionValidatedAt      DateTime?
  ActionLog               ActionLog[]
  BusinessProfile         BusinessProfile?
  Campaign                Campaign[]
  Integration             Integration[]
  Lead                    Lead[]
  Message                 Message[]
  MessageTemplate         MessageTemplate[]
  Notification            Notification[]
  SmartList               SmartList[]
  TeamMember              TeamMember[]
  Proxy                   Proxy?            @relation(fields: [proxyId], references: [id])
  WorkerLog               WorkerLog[]
}

model WorkerLog {
  id           String    @id
  userId       String
  campaignId   String?
  leadId       String?
  action       String
  status       String
  errorMessage String?
  createdAt    DateTime  @default(now())
  Campaign     Campaign? @relation(fields: [campaignId], references: [id])
  Lead         Lead?     @relation(fields: [leadId], references: [id])
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum LeadStatus {
  IMPORTED
  PENDING
  CONNECTED
  REPLIED
  BOUNCED
}

enum LinkedinPlan {
  BASIC
  PREMIUM
  SALES_NAV
}

enum ProxyTier {
  ECONOMY
  RESIDENTIAL
}

enum SubscriptionTier {
  FREE
  CORE
  PRO
  ADVANCED
  PLUS
  EXPERT
  ULTIMATE
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}
