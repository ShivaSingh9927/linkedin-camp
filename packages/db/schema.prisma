generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER & AUTH ---

enum PlanTier {
  FREE
  PRO
  ADVANCED
}

model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  passwordHash          String
  tier                  PlanTier @default(FREE)
  
  // LinkedIn Session
  linkedinCookie        String?  // Extension or raw sync
  persistentSessionPath String?  // Path to Playwright session dir
  
  // Cloud Worker State
  cloudWorkerActive     Boolean  @default(false)
  lastCloudActionAt     DateTime?
  
  // Relations
  campaigns             Campaign[]
  leads                 Lead[]
  notifications         Notification[]
  proxyId               String?
  assignedProxy         Proxy?   @relation(fields: [proxyId], references: [id])
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// --- CORE MODELS ---

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Campaign {
  id            String         @id @default(uuid())
  userId        String
  name          String
  status        CampaignStatus @default(DRAFT)
  
  // The sequence of actions (Invite -> Delay -> Message etc)
  workflow      Json           // Array of { type: string, delay: number, text: string }
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads         CampaignLead[]
  logs          WorkerLog[]
  
  createdAt     DateTime       @default(now())
}

enum LeadStatus {
  IMPORTED
  PENDING
  CONNECTED
  REPLIED
  BOUNCED
}

model Lead {
  id            String         @id @default(uuid())
  userId        String
  linkedinUrl   String
  firstName     String?
  lastName      String?
  headline      String?
  company       String?
  location      String?
  status        LeadStatus     @default(IMPORTED)
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignLeads CampaignLead[]
  workerLogs    WorkerLog[]

  createdAt     DateTime       @default(now())
  @@unique([userId, linkedinUrl])
}

model CampaignLead {
  id            String   @id @default(uuid())
  campaignId    String
  leadId        String
  
  stepIndex     Int      @default(0)
  lastActionAt  DateTime?
  isCompleted   Boolean  @default(false)
  
  status        LeadStatus @default(PENDING) // Specific progress in this campaign

  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
}

// --- LOGGING & NOTIFICATIONS ---

model WorkerLog {
  id            String   @id @default(uuid())
  userId        String
  campaignId    String?
  leadId        String?
  action        String
  status        String   // SUCCESS, FAILED
  errorMessage  String?
  createdAt     DateTime @default(now())

  campaign      Campaign? @relation(fields: [campaignId], references: [id])
  lead          Lead?     @relation(fields: [leadId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  meta      Json?    // { leadId, campaignId, etc. }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// --- INFRASTRUCTURE ---

enum ProxyTier {
  ECONOMY
  RESIDENTIAL
}

model Proxy {
  id              String   @id @default(uuid())
  proxyIp         String   @unique
  proxyHost       String
  proxyPort       Int
  proxyUsername   String?
  proxyPassword   String?
  proxyCountry    String?
  tierClass       ProxyTier @default(ECONOMY)
  maxUsers        Int       @default(15)
  
  isAssigned      Boolean  @default(false)
  assignedUsers   User[]
  
  // Time-Slicing Concurrency Lock
  lockedUntil     DateTime?
  lockedByUserId  String?
  
  banned          Boolean  @default(false)
  bannedAt        DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
