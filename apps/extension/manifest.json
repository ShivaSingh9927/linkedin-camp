{
    "manifest_version": 3,
    "name": "AutoConnect - LinkedIn Outreach",
    "version": "1.1.0",
    "description": "Sync LinkedIn sessions and import leads directly to your CRM.",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "cookies",
        "storage",
        "tabs",
        "scripting",
        "sidePanel",
        "alarms"
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "host_permissions": [
        "*://*.linkedin.com/*",
        "https://linkedin-camp-web.vercel.app/*",
        "https://*.vercel.app/*",
        "https://linkedin-camp-production.up.railway.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*",
        "http://127.0.0.1:3000/*",
        "http://204.168.167.198:3001/*",
        "http://204.168.167.198:3000/*",
        "https://204.168.167.198:3001/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "inject.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "https://linkedin-camp-web.vercel.app/*",
                "https://*.vercel.app/*",
                "http://localhost:3000/*",
                "http://204.168.167.198:*/*"
            ],
            "js": [
                "dashboard-sync.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js"
            ],
            "matches": [
                "*://*.linkedin.com/*"
            ]
        }
    ]
}