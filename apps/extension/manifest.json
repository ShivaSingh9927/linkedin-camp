{
    "manifest_version": 3,
    "name": "AutoConnect - LinkedIn Outreach",
    "version": "1.0.0",
    "description": "Sync LinkedIn sessions and import leads directly to your CRM.",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "cookies",
        "storage",
        "tabs",
        "offscreen"
    ],
    "host_permissions": [
        "*://*.linkedin.com/*",
        "https://linkedin-camp-web.vercel.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*",
        "http://127.0.0.1:3000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://linkedin-camp-web.vercel.app/*",
                "http://localhost:3000/*"
            ],
            "js": [
                "dashboard-sync.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js"
            ],
            "matches": [
                "*://*.linkedin.com/*"
            ]
        }
    ]
}