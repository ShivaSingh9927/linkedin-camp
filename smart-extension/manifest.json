{
    "manifest_version": 3,
    "name": "Qampi — Lead Importer",
    "version": "1.3.0",
    "description": "Sync your LinkedIn session and import leads straight into Qampi.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "Open Qampi panel",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "permissions": [
        "storage",
        "tabs",
        "scripting",
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "host_permissions": [
        "*://*.linkedin.com/*",
        "https://api.qampi.com/*",
        "https://app.qampi.com/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.qampi.com https://app.qampi.com;"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "inject.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "https://app.qampi.com/*"
            ],
            "js": [
                "dashboard-sync.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js",
                "assets/logo.png"
            ],
            "matches": [
                "*://*.linkedin.com/*"
            ]
        }
    ]
}