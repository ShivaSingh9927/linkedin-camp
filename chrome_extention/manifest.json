{
  "manifest_version": 3,
  "name": "AutoConnect - LinkedIn Outreach",
  "version": "1.0.0",
  "description": "Sync LinkedIn sessions and import leads directly to your CRM.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Lead Importer"
  },
  "permissions": [
    "cookies",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "https://your-local-api.com/*" 
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}