# =============================================================================
# Production environment template.  Copy to .env.production on each server,
# fill in the values, and DO NOT commit the filled copy.  This file is the
# template only.  In Phase 6 (CI/CD), GitHub Actions Secrets will be the
# source of truth and these files will be generated on the server at deploy.
#
# Layout below is split by which server reads each variable.
# Replace PASTE_* placeholders with strong, unique values (use:  openssl rand -base64 32)
# =============================================================================

# -----------------------------------------------------------------------------
# COMMON — set on BOTH servers
# -----------------------------------------------------------------------------
# The host's private-network IP. Each server sets its own:
#   worker server  -> PRIVATE_IP=10.0.0.2
#   db/ai server   -> PRIVATE_IP=10.0.0.4
PRIVATE_IP=

# Anything that ever speaks to Postgres / Redis / AI-service uses these URLs.
# They all point at the db/ai server's private IP (10.0.0.4).
DATABASE_URL=postgresql://qampi:PASTE_POSTGRES_PASSWORD@10.0.0.4:5432/linkedin_camp
REDIS_URL=redis://default:PASTE_REDIS_PASSWORD@10.0.0.4:6379
AI_SERVICE_URL=http://10.0.0.4:8001

# Shared secret used by the AI service. Same value on both servers.
GROQ_API=PASTE_GROQ_API_KEY

# -----------------------------------------------------------------------------
# WORKER SERVER ONLY (10.0.0.2) — used by backend-api and backend-worker
# -----------------------------------------------------------------------------
# 32+ random bytes. Regenerate this when going to prod — never reuse dev value.
JWT_SECRET=PASTE_LONG_RANDOM_STRING

# OAuth + email integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft (Azure App Registration) — redirect URI:
#   https://api.qampi.com/api/v1/auth/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# LinkedIn ("Sign In with LinkedIn using OpenID Connect") — redirect URI:
#   https://api.qampi.com/api/v1/auth/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
OUTLOOK_EMAIL=
OUTLOOK_APP_PASSWORD=

# Public base URLs used to build the OAuth redirect dance (no trailing slash).
# BACKEND_PUBLIC_URL must match the redirect URIs registered above.
BACKEND_PUBLIC_URL=https://api.qampi.com
APP_PUBLIC_URL=https://app.qampi.com

# PostHog (web analytics + session replay). Set the NEXT_PUBLIC_* pair in Vercel.
# Blank = disabled. US host shown; EU = https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Backend (server-side) capture — same project key so events merge. Set on the
# worker box env, not Vercel. Powers linkedin_connected / leads_imported / first_reply_received.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Public URLs (no trailing slash). Frontend is on Vercel.
FRONTEND_URL=https://app.qampi.com
BACKEND_URL=https://api.qampi.com
CORS_ORIGIN=https://app.qampi.com

# Hetzner Object Storage (qampi-user-data bucket) — for session JSON files.
# Generate the access key pair in the Hetzner console -> Object Storage -> Manage credentials.
S3_ENDPOINT=https://hel1.your-objectstorage.com
S3_BUCKET=qampi-user-data
S3_REGION=hel1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# DB/AI SERVER ONLY (10.0.0.4)
# -----------------------------------------------------------------------------
# Postgres bootstraps with these values on first start. After that, changing
# them here does NOT change the actual user — you'd need to ALTER USER inside psql.
POSTGRES_USER=qampi
POSTGRES_PASSWORD=PASTE_POSTGRES_PASSWORD
POSTGRES_DB=linkedin_camp

# Redis auth — picked up via redis-server --requirepass
REDIS_PASSWORD=PASTE_REDIS_PASSWORD
